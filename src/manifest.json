{
  "manifest_version": 3,
  "name": "Bookmate Downloader",
  "version": "1.3",
  "description": "Download Bookmate and Яндекс Книги books as EPUB files directly from your browser.",
  "permissions": [
    "cookies",
    "downloads",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.bookmate.com/*",
    "https://books.yandex.ru/*",
    "https://*.yandex.net/*",
    "https://*.yandexcloud.net/*",
    "https://audio.bookmate.ru/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.bookmate.com/*",
        "https://books.yandex.ru/*"
      ],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bookmate Downloader"
  }
}
